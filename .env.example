# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI (for GPT-4o-mini + text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Anthropic (for Claude Haiku — alternative to OpenAI)
ANTHROPIC_API_KEY=sk-ant-...

# RAG tuning
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.3
